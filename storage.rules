rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Property images
    match /properties/{userId}/{imageId} {
      allow read: if true; // anyone can view images
      
      // Only authenticated users can upload to their own folder, max 5MB, specific mime types
      allow create, update: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size <= 5 * 1024 * 1024
        && (request.resource.contentType == 'image/jpeg' 
            || request.resource.contentType == 'image/png' 
            || request.resource.contentType == 'image/webp');
            
      // Only the owner of the folder or an admin can delete
      allow delete: if request.auth != null && (request.auth.uid == userId || firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)));
    }

    // Brochures path
    match /brochures/{userId}/{fileId} {
      allow read: if true;
      
      // Upload: max 10mb, type PDF
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
        
      allow delete: if request.auth != null && (request.auth.uid == userId || firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)));
    }
  }
}
