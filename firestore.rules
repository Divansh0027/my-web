// Production rules for Shiv Saya Properties
// Last updated: Phase 3 (Secured)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check in rules: Support both static master admin and dynamically registered admins
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'admin@shivsayaproperties.com' ||
        request.auth.token.email == 'divansh0027@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // Validation helper for Property
    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'city', 'type', 'category'])
        && data.keys().size() <= 35
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && (data.price is int || data.price is float) && data.price >= 0
        && data.location is string && data.location.size() > 0 && data.location.size() <= 500
        && data.city is string && data.city.size() > 0 && data.city.size() <= 100
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100;
    }

    // Validation helper for Enquiry
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'phone', 'propertyId', 'propertyName', 'type'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 30
        && data.propertyId is string && data.propertyId.size() > 0 && data.propertyId.size() <= 128
        && data.propertyName is string && data.propertyName.size() > 0 && data.propertyName.size() <= 300
        && (data.type == 'enquiry' || data.type == 'visit')
        // Optional message string sizing validation (Case 11: Too Long Message in Enquiry)
        && (!data.keys().contains('message') || (data.message is string && data.message.size() <= 1000))
        // Optional user fields validation
        && (!data.keys().contains('userId') || (data.userId is string && data.userId.size() <= 128))
        && (!data.keys().contains('userEmail') || (data.userEmail is string && data.userEmail.size() <= 200));
    }

    // Users collection (Issue 4: Restrict profile reads)
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId && (!incoming().keys().contains('banned') || incoming().banned == existing().banned)) || isAdmin();
      allow delete: if isAdmin();

      // Saved properties collection nested matching (Issue 12: Typing and hijacking)
      match /favorites/{propertyId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Properties collection
    match /properties/{propertyId} {
      allow read: if (resource.data.status == 'live') || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email)) || isAdmin();
      
      allow create: if (isSignedIn() && incoming().status == 'pending' && (incoming().userId == request.auth.uid || incoming().userEmail == request.auth.token.email) && isValidProperty(incoming())) || isAdmin();
      
      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        (existing().userId == request.auth.uid || existing().userEmail == request.auth.token.email) && 
        incoming().status == 'pending' &&
        incoming().userId == existing().userId &&
        isValidProperty(incoming())
      );
      
      allow delete: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        (existing().userId == request.auth.uid || existing().userEmail == request.auth.token.email)
      );
    }

    // Enquiries collection (Issue 5: Schema check and validation rules)
    match /enquiries/{enquiryId} {
      allow create: if isValidId(enquiryId) && isValidEnquiry(incoming());
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow update, delete: if isAdmin();
    }

    // Dynamic system configurations (Issue 8 & 11)
    match /controls/{controlId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // List of Dynamically authorized Admins (Issue 3)
    match /admins/{adminEmail} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
