// Production rules for Shiv Saya Properties
// Last updated: Phase 3

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check in rules
    // Production rules for Shiv Saya Properties
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'admin@shivsayaproperties.com'; 
    }

    // Validation helper for Property
    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'city', 'type', 'category'])
        && data.keys().size() <= 35
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && (data.price is int || data.price is float) && data.price >= 0
        && data.location is string && data.location.size() > 0 && data.location.size() <= 500
        && data.city is string && data.city.size() > 0 && data.city.size() <= 100
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100;
    }

    // Users collection:
    // - Anyone can read a user document (for displaying names)
    // - Only the authenticated user can write their own document
    // - Only admin emails can update banned field
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId && (!incoming().keys().contains('banned') || incoming().banned == existing().banned)) || isAdmin();
      allow delete: if isAdmin();

      // Saved properties collection nested matching
      match /favorites/{propertyId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Properties collection:
    // - Anyone can read properties where status is "live"
    // - Authenticated users can read their own pending/rejected
    // - Authenticated users can create new properties with status forced to "pending" always
    // - Users can update ONLY their own properties that are still in "pending" status
    // - Only admins can update status field to "live" or "rejected"
    // - Only admins can delete any property
    // - Owners can delete their own pending properties
    match /properties/{propertyId} {
      allow read: if (resource.data.status == 'live') || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      
      allow create: if (isSignedIn() && incoming().status == 'pending' && (incoming().userId == request.auth.uid || incoming().userEmail == request.auth.token.email) && isValidProperty(incoming())) || isAdmin();
      
      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        (existing().userId == request.auth.uid || existing().userEmail == request.auth.token.email) && 
        incoming().status == 'pending' &&
        incoming().userId == existing().userId &&
        isValidProperty(incoming())
      );
      
      allow delete: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        (existing().userId == request.auth.uid || existing().userEmail == request.auth.token.email)
      );
    }

    // Enquiries collection:
    // - Authenticated users can create enquiries
    // - Only admins can read all enquiries
    // - Users can read their own enquiries
    // - Only admins can update or delete enquiries
    match /enquiries/{enquiryId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow update, delete: if isAdmin();
    }
  }
}
