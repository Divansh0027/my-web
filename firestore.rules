rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation helper for Enquiries
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'phone', 'propertyId', 'propertyName', 'type'])
        && data.keys().size() <= 8
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 25
        && (!data.keys().contains('message') || (data.message is string && data.message.size() <= 2000))
        && (!data.keys().contains('id') || (data.id is string && data.id.size() <= 128))
        && (!data.keys().contains('dateStr') || (data.dateStr is string && data.dateStr.size() <= 128))
        && data.propertyId is string && data.propertyId.size() <= 128
        && data.propertyName is string && data.propertyName.size() <= 300
        && data.type is string && (data.type == 'enquiry' || data.type == 'visit');
    }

    // Validation helper for Property
    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'city', 'type', 'category'])
        && data.keys().size() <= 30
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && (data.price is int || data.price is float) && data.price >= 0
        && data.location is string && data.location.size() > 0 && data.location.size() <= 500
        && data.city is string && data.city.size() > 0 && data.city.size() <= 100
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && (!data.keys().contains('description') || (data.description is string && data.description.size() <= 5000))
        && (!data.keys().contains('priceString') || (data.priceString is string && data.priceString.size() <= 50))
        && (!data.keys().contains('locality') || (data.locality is string && data.locality.size() <= 150))
        && (!data.keys().contains('bhk') || (data.bhk == null || data.bhk is int || data.bhk is float))
        && (!data.keys().contains('area') || (data.area is int || data.area is float))
        && (!data.keys().contains('areaUnit') || (data.areaUnit is string && data.areaUnit.size() <= 20))
        && (!data.keys().contains('floor') || (data.floor is string && data.floor.size() <= 50))
        && (!data.keys().contains('facing') || (data.facing is string && data.facing.size() <= 50))
        && (!data.keys().contains('ageOfProperty') || (data.ageOfProperty is string && data.ageOfProperty.size() <= 50))
        && (!data.keys().contains('furnishing') || (data.furnishing is string && data.furnishing.size() <= 50))
        && (!data.keys().contains('images') || (data.images is list && data.images.size() <= 20))
        && (!data.keys().contains('amenities') || (data.amenities is list && data.amenities.size() <= 50))
        && (!data.keys().contains('landmarks') || (data.landmarks is list && data.landmarks.size() <= 20))
        && (!data.keys().contains('featured') || (data.featured is bool))
        && (!data.keys().contains('newLaunch') || (data.newLaunch is bool))
        && (!data.keys().contains('verified') || (data.verified is bool))
        && (!data.keys().contains('status') || (data.status is string && data.status.size() <= 100))
        && (!data.keys().contains('postedBy') || (data.postedBy is string && data.postedBy.size() <= 100))
        && (!data.keys().contains('postedDate') || (data.postedDate is string && data.postedDate.size() <= 50));
    }

    // Validation helper for Favorites
    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'propertyId'])
        && data.keys().size() <= 3
        && data.userId is string && data.userId.size() <= 128
        && data.propertyId is string && data.propertyId.size() <= 128
        && (!data.keys().contains('savedAt') || (data.savedAt is string && data.savedAt.size() <= 128));
    }

    // Properties: readable by anyone, writable if matching schema validation helper
    match /properties/{propertyId} {
      allow get, list: if true;
      allow create, update: if isValidId(propertyId) && isValidProperty(incoming());
      allow delete: if isSignedIn();
    }

    // Enquiries: anyone can submit if static validation passes
    match /enquiries/{enquiryId} {
      allow create: if isValidId(enquiryId) && isValidEnquiry(incoming());
      allow get, list, update, delete: if false;
    }

    // Favorites: authenticated users can manage their own wishlist
    match /users/{userId}/favorites/{propertyId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidFavorite(incoming()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
