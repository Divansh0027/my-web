// Production rules for Shiv Saya Properties
// Last updated: Phase 4 (UID-Based Security)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: Strict UID-based validation using admins collection.
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'divansh0027@gmail.com'
      );
    }

    // Validation helper for Property
    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'city', 'type', 'category'])
        && data.keys().size() <= 35
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 300
        && (data.price is int || data.price is float) && data.price >= 0
        && data.location is string && data.location.size() > 0 && data.location.size() <= 500
        && data.city is string && data.city.size() > 0 && data.city.size() <= 100
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100;
    }

    // Validation helper for Enquiry
    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'phone', 'propertyId', 'propertyName', 'type'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 30
        && data.propertyId is string && data.propertyId.size() > 0 && data.propertyId.size() <= 128
        && data.propertyName is string && data.propertyName.size() > 0 && data.propertyName.size() <= 300
        && (data.type == 'enquiry' || data.type == 'visit');
    }

    // Users collection
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId && (!incoming().keys().hasAny(['banned', 'isAdmin']) || isAdmin())) || isAdmin();
      allow delete: if isAdmin();

      // Saved properties collection
      match /favorites/{propertyId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Properties collection
    match /properties/{propertyId} {
      allow read: if true;
      
      allow create: if (isSignedIn() && incoming().status == 'pending' && incoming().userId == request.auth.uid && isValidProperty(incoming())) || isAdmin();
      
      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        existing().userId == request.auth.uid && 
        incoming().status == 'pending' &&
        incoming().userId == existing().userId &&
        isValidProperty(incoming())
      );
      
      allow delete: if isAdmin() || (
        isSignedIn() && 
        existing().status == 'pending' && 
        existing().userId == request.auth.uid
      );
    }

    // Enquiries collection
    match /enquiries/{enquiryId} {
      allow create: if isValidId(enquiryId) && isValidEnquiry(incoming());
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /controls/{controlId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminUid} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
