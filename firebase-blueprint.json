{
  "entities": {
    "Property": {
      "title": "Property Listing",
      "description": "A property listed for sale, rent, commercial or plots in Delhi NCR.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "priceString": { "type": "string" },
        "location": { "type": "string" },
        "locality": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "bhk": { "type": "number" },
        "area": { "type": "number" },
        "areaUnit": { "type": "string" },
        "floor": { "type": "string" },
        "facing": { "type": "string" },
        "ageOfProperty": { "type": "string" },
        "furnishing": { "type": "string" },
        "images": { "type": "array" },
        "amenities": { "type": "array" },
        "featured": { "type": "boolean" },
        "newLaunch": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "status": { "type": "string" },
        "postedBy": { "type": "string" },
        "postedDate": { "type": "string" }
      },
      "required": ["id", "title", "price", "location", "city", "type", "category"]
    },
    "Enquiry": {
      "title": "Property Enquiry",
      "description": "An enquiry or visit scheduled for a specific property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "propertyId": { "type": "string" },
        "propertyName": { "type": "string" },
        "dateStr": { "type": "string" },
        "type": { "type": "string", "enum": ["enquiry", "visit"] }
      },
      "required": ["name", "phone", "propertyId", "propertyName", "type"]
    },
    "Favorite": {
      "title": "User Favorite Property",
      "description": "A property favorited/saved by a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "savedAt": { "type": "string" }
      },
      "required": ["userId", "propertyId"]
    }
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of all premium property listings."
    },
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "Contact messages and site visit scheduling requests."
    },
    "/users/{userId}/favorites/{propertyId}": {
      "schema": "Favorite",
      "description": "User specific property wishlists."
    }
  }
}
